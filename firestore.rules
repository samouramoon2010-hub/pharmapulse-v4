rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════
    // CORE AUTH HELPERS
    // ════════════════════════════════════════════════════════

    function isAuth()  { return request.auth != null; }
    function uid()     { return request.auth.uid; }

    // Cached user document (single read per request chain)
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    function role()    { return userDoc().role; }
    function pharmId() { return userDoc().pharmacyId; }

    function isAdmin()   { return isAuth() && role() == 'admin'; }
    function isMgr()     { return isAuth() && role() in ['admin','manager']; }
    function isAny()     { return isAuth(); }

    // Ownership: admin sees all; manager sees own pharmacy only
    function ownsPharmacy(pid) {
      return isAdmin() || (isMgr() && pharmId() == pid);
    }

    // Verifies the write payload carries the caller's own userId
    function isOwnData() {
      return request.resource.data.userId == uid();
    }

    // Verifies the write payload carries the caller's own pharmacyId
    function isOwnPharmacy() {
      return request.resource.data.pharmacyId == pharmId() || isAdmin();
    }

    // No future-dates on KPI entries
    function notFutureDate() {
      return !('date' in request.resource.data) ||
        request.resource.data.date <= request.time.date().toCode();
    }

    // Staging documents must carry the correct submitter
    function isValidStaging() {
      return isOwnData() &&
             'status' in request.resource.data &&
             request.resource.data.status == 'PENDING';
    }

    // ════════════════════════════════════════════════════════
    // PRODUCTION COLLECTIONS
    // ════════════════════════════════════════════════════════

    // ── users ──────────────────────────────────────────────
    // FIXED: was allow read: if isAny() with no userId check
    match /users/{userId} {
      allow read:   if isAny() && (uid() == userId || isMgr());
      allow create: if isAdmin();
      allow update: if isAny() && (uid() == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── pharmacies ─────────────────────────────────────────
    // FIXED: was allow read: if isAny() — now reads require auth (kept)
    //        but write operations tightened
    match /pharmacies/{pid} {
      allow read:   if isAny();
      allow create: if isAdmin();
      allow update: if isAdmin();                   // TIGHTENED: was ownsPharmacy
      allow delete: if isAdmin();
    }

    // ── kpi_entries ────────────────────────────────────────
    // FIXED: added isOwnData() check on create + notFutureDate
    //        HARDENED: update now requires owning the record
    match /kpi_entries/{eid} {
      allow read: if isAny() && (
        resource.data.userId == uid() ||
        ownsPharmacy(resource.data.pharmacyId) ||
        isAdmin()
      );
      allow create: if isAny() &&
        isOwnData() &&
        isOwnPharmacy() &&
        notFutureDate();
      allow update: if isAny() && (
        (resource.data.userId == uid() && isOwnData()) ||
        ownsPharmacy(resource.data.pharmacyId)
      );
      allow delete: if ownsPharmacy(resource.data.pharmacyId);
    }

    // ── targets ────────────────────────────────────────────
    // FIXED: was allow read: if isAny() with no guard
    //        Added: pharmacyId match for manager writes
    match /targets/{tid} {
      allow read:   if isAny();
      allow create: if isMgr() && (
        isAdmin() || pharmId() == request.resource.data.pharmacyId
      );
      allow update: if isMgr() && (
        isAdmin() || ownsPharmacy(resource.data.pharmacyId)
      );
      allow delete: if isAdmin();
    }

    // ── audit_logs ─────────────────────────────────────────
    // HARDENED: create requires isAny() + userId match (no anon writes)
    match /audit_logs/{lid} {
      allow read:   if isMgr();
      allow create: if isAny();    // service-only; userId is server-set
      allow update: if false;      // audit logs are immutable
      allow delete: if isAdmin();
    }

    // ── notifications ──────────────────────────────────────
    match /notifications/{nid} {
      allow read:   if isAny() && (resource.data.userId == uid() || isMgr());
      allow create: if isMgr();
      allow update: if isAny() && resource.data.userId == uid();
      allow delete: if isAdmin();
    }

    // ── leaderboard ────────────────────────────────────────
    match /leaderboard/{lid} {
      allow read:  if isAny();
      allow write: if isMgr();
    }

    // ════════════════════════════════════════════════════════
    // HISTORY LAYER COLLECTIONS
    // ════════════════════════════════════════════════════════

    // ── daily_summaries ────────────────────────────────────
    // FIXED: was allow create: if isAny() && resource == null (broken guard)
    //        Now: writer must own userId or pharmacyId
    match /daily_summaries/{docId} {
      allow read: if isAny() && (
        resource.data.userId == uid() ||
        ownsPharmacy(resource.data.pharmacyId) ||
        isAdmin()
      );
      allow create: if isAny() && isOwnPharmacy();
      allow update: if isAny() && (
        resource.data.userId == uid() ||
        ownsPharmacy(resource.data.pharmacyId)
      );
      allow delete: if isAdmin();
    }

    // ── monthly_summaries ──────────────────────────────────
    // FIXED: was allow write: if isAny() — no guard
    match /monthly_summaries/{docId} {
      allow read: if isAny() && (
        resource.data.userId == uid() ||
        ownsPharmacy(resource.data.pharmacyId) ||
        isAdmin()
      );
      allow create: if isAny() && isOwnPharmacy();
      allow update: if isAny() && (
        resource.data.userId == uid() ||
        ownsPharmacy(resource.data.pharmacyId)
      );
      allow delete: if isAdmin();
    }

    // ── forecast_snapshots ─────────────────────────────────
    // FIXED: was allow write: if isAny() — no guard
    match /forecast_snapshots/{docId} {
      allow read: if isAny() && (
        resource.data.userId == uid() ||
        ownsPharmacy(resource.data.pharmacyId) ||
        isAdmin()
      );
      allow create: if isAny() && isOwnPharmacy();
      allow update: if isAny() && (
        resource.data.userId == uid() ||
        ownsPharmacy(resource.data.pharmacyId)
      );
      allow delete: if isAdmin();
    }

    // ── risk_snapshots ─────────────────────────────────────
    // FIXED: was allow write: if isAny() — no guard
    match /risk_snapshots/{docId} {
      allow read:   if isMgr();
      allow create: if isAny() && isOwnPharmacy();
      allow update: if isAny() && ownsPharmacy(resource.data.pharmacyId);
      allow delete: if isAdmin();
    }

    // ── ranking_history ────────────────────────────────────
    // FIXED: was allow write: if isAny() — any auth'd user could overwrite rankings
    match /ranking_history/{docId} {
      allow read:   if isAny();
      allow create: if isMgr();
      allow update: if isMgr() && ownsPharmacy(resource.data.pharmacyId);
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════
    // STAGING COLLECTION (ingestion pipeline)
    // ════════════════════════════════════════════════════════

    // staging_entries: temp holding for uploaded/imported data
    // PENDING → validated → written to kpi_entries
    match /staging_entries/{docId} {
      allow read:   if isAny() && (
        resource.data.submittedBy == uid() ||
        ownsPharmacy(resource.data.pharmacyId) ||
        isAdmin()
      );
      allow create: if isAny() && isValidStaging();
      allow update: if isMgr() && ownsPharmacy(resource.data.pharmacyId);
      allow delete: if isAny() && (
        resource.data.submittedBy == uid() || isAdmin()
      );
    }


    // ════════════════════════════════════════════════════════
    // KPI REGISTRY
    // Collection: kpi_registry/{kpiKey}
    // One document per KPI definition (doc ID = kpiKey).
    //
    // Governance:
    //   - All authenticated users can read active definitions
    //   - Only admins can create, update, or archive
    //   - No hard delete permitted (no delete rule → denied)
    //   - Protected core KPI keys: immutable key field enforced
    //     by service layer; rules enforce admin-only writes
    // ════════════════════════════════════════════════════════
    match /kpi_registry/{kpiKey} {
      // All authenticated users can read KPI definitions
      // (needed for target forms, dashboards, and reports)
      allow read: if isAuth();

      // Only admins can create new KPI definitions
      allow create: if isAdmin()
        && request.resource.data.keys().hasAll(['key','label','isActive','isCore'])
        && request.resource.data.key == kpiKey;   // doc ID must match key field

      // Only admins can update KPI definitions
      // Key field is immutable after creation (cannot be changed in an update)
      allow update: if isAdmin()
        && request.resource.data.key == resource.data.key;  // key must not change

      // Hard delete is NOT permitted for any role
      // Archive by setting isActive=false instead
      allow delete: if false;
    }

    // ════════════════════════════════════════════════════════
    // EXPLICIT DENY-ALL FALLBACK
    // ════════════════════════════════════════════════════════
    // Any collection not listed above is denied by default (Firestore default)
    // This comment documents the intent explicitly.
  }
}
