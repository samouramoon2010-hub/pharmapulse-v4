{
  "compilerOptions": {
    "target":           "ES2020",
    "lib":              ["ES2020", "DOM", "DOM.Iterable"],
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "strict":           true,
    "noEmit":           true,
    "skipLibCheck":     true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "isolatedModules":  true,
    "jsx":              "react-jsx",
    "baseUrl":          ".",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
