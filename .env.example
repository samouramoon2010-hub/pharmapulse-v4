# ============================================================
# PharmaPulse — Environment Variables
# Copy to .env and fill your values. NEVER commit .env to Git.
# ============================================================

# ── Firebase Configuration ────────────────────────────────────
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234

# ── App Mode ──────────────────────────────────────────────────
# true  → Demo mode (no Firebase, local state only)
# false → Production mode (requires Firebase config above)
VITE_DEMO_MODE=false

# NOTE: VITE_FIREBASE_API_KEY is also used by the User Service
# to call Firebase Identity Toolkit REST API for creating users.
# Make sure "Email/Password" sign-in is enabled in Firebase Console.
